<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Add Filament - Details</title>
</head>
<body class="bg-gray-100 text-gray-800 font-sans min-h-screen flex flex-col items-center justify-center p-0 sm:p-4">
    <div class="relative w-full max-w-md min-h-screen md:min-h-[850px] md:h-[850px] bg-surface md:rounded-[40px] md:shadow-2xl overflow-hidden flex flex-col">

        <header class="relative z-30 px-6 pt-6 pb-4 bg-white border-b border-gray-100 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <a href="/filaments/new" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-50 text-gray-600 hover:bg-gray-100 active:scale-95 transition-all border border-gray-100">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <h1 class="text-lg font-bold text-text-main tracking-tight">Details</h1>
                <div class="w-10"></div>
            </div>
            <div class="flex flex-col items-center justify-center gap-2">
                <div class="flex gap-2">
                    <div class="h-1.5 w-8 bg-primary rounded-full opacity-30"></div>
                    <div class="h-1.5 w-8 bg-primary rounded-full shadow-[0_0_10px_rgba(249,115,22,0.3)]"></div>
                </div>
                <p class="text-center text-[10px] font-semibold text-text-muted uppercase tracking-wider">Step 2 of 2: Basic Info</p>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto hide-scrollbar bg-surface relative">
            <form id="filament-form" action="/filaments" method="POST" enctype="multipart/form-data">
                <div class="px-6 pt-6 pb-24 space-y-6 animate-fade-in">

                    <!-- Photo upload -->
                    <div class="flex flex-col items-center gap-3">
                        <div class="relative group">
                            <div id="photo-preview" class="w-24 h-24 rounded-2xl border-4 border-white shadow-lg overflow-hidden bg-gray-200 flex items-center justify-center">
                                <i class="fa-solid fa-camera text-2xl text-gray-400"></i>
                            </div>
                            <label class="absolute -bottom-2 -right-2 w-8 h-8 rounded-full bg-primary text-white shadow-lg flex items-center justify-center hover:bg-orange-600 cursor-pointer">
                                <i class="fa-solid fa-camera text-xs"></i>
                                <input type="file" name="photo" accept="image/*" class="hidden" onchange="previewPhoto(this)">
                            </label>
                        </div>
                    </div>

                    <!-- Core Info -->
                    <div class="bg-white p-5 rounded-2xl shadow-card space-y-5 border border-gray-100">
                        <div class="space-y-1.5">
                            <label class="text-xs font-semibold text-text-muted uppercase tracking-wider ml-1">Brand <span class="text-red-500">*</span></label>
                            <input name="brand" type="text" required class="w-full bg-input-bg text-text-main font-semibold px-4 py-3 rounded-xl border-none focus:ring-2 focus:ring-primary/50 transition-all" placeholder="e.g. Prusament">
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-1.5">
                                <label class="text-xs font-semibold text-text-muted uppercase tracking-wider ml-1">Material</label>
                                <select name="material" class="w-full bg-input-bg text-text-main font-semibold px-4 py-3 rounded-xl border-none focus:ring-2 focus:ring-primary/50 appearance-none cursor-pointer">
                                    <option>PLA</option><option>PETG</option><option>ABS</option><option>TPU</option><option>ASA</option><option>Other</option>
                                </select>
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-xs font-semibold text-text-muted uppercase tracking-wider ml-1">Color <span class="text-red-500">*</span></label>
                                <div class="flex items-center gap-2 bg-input-bg px-3 py-3 rounded-xl focus-within:ring-2 focus-within:ring-primary/50">
                                    <input type="color" name="color_hex" value="#F97316" class="w-5 h-5 rounded-full border-0 p-0 cursor-pointer">
                                    <input name="color" type="text" required class="w-full bg-transparent border-none p-0 text-text-main font-semibold focus:ring-0 text-sm" placeholder="Color name">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Remaining & Status -->
                    <div class="bg-white p-5 rounded-2xl shadow-card space-y-5 border border-gray-100">
                        <div class="space-y-3">
                            <div class="flex justify-between items-end">
                                <label class="text-xs font-semibold text-text-muted uppercase tracking-wider ml-1">Remaining</label>
                                <div class="flex items-center gap-1 text-primary font-bold bg-orange-50 px-2 py-0.5 rounded-md text-sm border border-orange-100">
                                    <span id="remaining-value">100</span>%
                                </div>
                            </div>
                            <input type="range" name="remaining" min="0" max="100" value="100" class="w-full" id="remaining-slider" oninput="document.getElementById('remaining-value').textContent = this.value">
                            <div class="flex justify-between text-[10px] text-gray-400 mt-1 font-medium px-1"><span>Empty</span><span>Full</span></div>
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-xs font-semibold text-text-muted uppercase tracking-wider ml-1">Total Weight (g)</label>
                            <input type="number" name="total_weight" value="1000" class="w-full bg-input-bg text-text-main font-semibold px-4 py-3 rounded-xl border-none focus:ring-2 focus:ring-primary/50">
                        </div>

                        <div class="h-px bg-gray-100 w-full"></div>

                        <div class="space-y-2">
                            <label class="text-xs font-semibold text-text-muted uppercase tracking-wider ml-1">Status</label>
                            <div class="flex bg-input-bg p-1 rounded-xl">
                                <label class="flex-1 py-2 rounded-lg text-sm font-semibold text-center cursor-pointer transition-all status-label" data-status="sealed">
                                    <input type="radio" name="status" value="sealed" checked class="hidden"><i class="fa-solid fa-box text-xs mr-1"></i>Sealed
                                </label>
                                <label class="flex-1 py-2 rounded-lg text-sm font-medium text-center cursor-pointer transition-all status-label" data-status="open">
                                    <input type="radio" name="status" value="open" class="hidden"><i class="fa-solid fa-box-open text-xs mr-1"></i>Open
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Optional Details -->
                    <div class="bg-white p-5 rounded-2xl shadow-card space-y-4 border border-gray-100">
                        <div class="flex items-center justify-between cursor-pointer" onclick="document.getElementById('optional-fields').classList.toggle('hidden'); document.getElementById('opt-chevron').classList.toggle('rotate-180')">
                            <span class="text-sm font-semibold text-text-main">Optional Details</span>
                            <i id="opt-chevron" class="fa-solid fa-chevron-down text-gray-400 transition-transform duration-300"></i>
                        </div>
                        <div id="optional-fields" class="space-y-4 hidden">
                            <div class="space-y-1.5">
                                <label class="text-xs font-semibold text-text-muted uppercase tracking-wider ml-1">Location</label>
                                <div class="relative">
                                    <i class="fa-solid fa-location-dot absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                                    <input type="text" name="location" class="w-full bg-input-bg text-text-main text-sm px-4 pl-10 py-3 rounded-xl border-none focus:ring-2 focus:ring-primary/50" placeholder="e.g. Shelf A, Dry Box 2">
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-xs font-semibold text-text-muted uppercase tracking-wider ml-1">Notes</label>
                                <textarea name="notes" class="w-full bg-input-bg text-text-main text-sm px-4 py-3 rounded-xl border-none focus:ring-2 focus:ring-primary/50 min-h-[80px] resize-none" placeholder="Batch number, printing temps, etc."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </main>

        <div class="absolute bottom-0 left-0 right-0 bg-white border-t border-gray-100 p-4 z-40 shadow-[0_-4px_20px_rgba(0,0,0,0.05)]">
            <button type="submit" form="filament-form" class="w-full bg-primary text-white font-bold text-lg py-4 rounded-2xl shadow-floating hover:bg-orange-600 active:scale-[0.98] transition-all flex items-center justify-center gap-2 group">
                <span>Save Filament</span>
                <i class="fa-solid fa-check bg-white/20 rounded-full p-1 text-xs"></i>
            </button>
        </div>
    </div>

    <script>
        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const preview = document.getElementById('photo-preview');
                    preview.innerHTML = '<img class="w-full h-full object-cover" src="' + e.target.result + '">';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Load pending photo from session storage
        const pending = sessionStorage.getItem('pendingPhoto');
        if (pending) {
            document.getElementById('photo-preview').innerHTML = '<img class="w-full h-full object-cover" src="' + pending + '">';
            sessionStorage.removeItem('pendingPhoto');
        }

        // Status toggle
        document.querySelectorAll('.status-label').forEach(label => {
            label.addEventListener('click', () => {
                document.querySelectorAll('.status-label').forEach(l => {
                    l.classList.remove('bg-white', 'text-primary', 'shadow-sm', 'font-semibold');
                    l.classList.add('text-gray-500', 'font-medium');
                });
                label.classList.add('bg-white', 'text-primary', 'shadow-sm', 'font-semibold');
                label.classList.remove('text-gray-500', 'font-medium');
            });
        });
        // Init first
        document.querySelector('.status-label[data-status="sealed"]').classList.add('bg-white', 'text-primary', 'shadow-sm');
    </script>
</body>
</html>
