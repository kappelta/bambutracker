<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Quick Setup - BambuTracker</title>
    <style>
        .selection-card.selected { border-color: #F97316; background-color: #FFF7ED; }
        .selection-card.selected .check-icon { opacity: 1; transform: scale(1); }
    </style>
</head>
<body class="bg-gray-100 text-gray-800 font-sans min-h-screen flex flex-col items-center justify-center overflow-hidden p-0 md:p-4">
    <div class="relative w-full max-w-md h-[100dvh] md:h-[850px] bg-white md:rounded-[40px] md:shadow-2xl overflow-hidden flex flex-col">

        <header class="relative z-20 flex justify-between items-center px-4 md:px-6 pt-6 md:pt-8 pb-4 bg-white">
            <a href="/" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-50 text-gray-500 transition-colors">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div class="flex flex-col items-center">
                <span class="text-[10px] md:text-xs font-semibold text-primary tracking-wider uppercase">Quick Setup</span>
                <div class="flex items-center gap-1 mt-1"><div class="w-8 md:w-12 h-1 bg-primary rounded-full"></div></div>
            </div>
            <a href="/filaments" class="text-sm font-bold text-primary hover:text-orange-600 transition-colors px-2 py-1">DONE</a>
        </header>

        <main class="flex-1 overflow-y-auto px-4 md:px-6 pt-2 pb-32 relative z-10">
            <div class="mb-6 md:mb-8 text-center">
                <h1 class="text-xl md:text-2xl font-bold text-gray-900 mb-2">Preferences</h1>
                <p class="text-gray-500 text-xs md:text-sm">Customize how you want to track your filament usage.</p>
            </div>

            <form action="/settings?_method=PUT" method="POST" id="setup-form">
                <input type="hidden" name="_method" value="PUT">

                <section class="mb-8 md:mb-10">
                    <h2 class="text-xs md:text-sm font-semibold text-gray-900 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-scale-balanced text-primary text-xs"></i> Tracking Mode
                    </h2>
                    <div class="grid grid-cols-2 gap-3 md:gap-4">
                        <div id="mode-percent" class="selection-card <%= settings.tracking_mode === 'percent' ? 'selected' : '' %> cursor-pointer relative p-4 rounded-2xl border-2 <%= settings.tracking_mode === 'percent' ? 'border-primary bg-orange-50' : 'border-gray-100 bg-white' %> transition-all duration-200 hover:shadow-md" onclick="selectMode('percent')">
                            <div class="absolute top-3 right-3 check-icon w-5 h-5 bg-primary text-white rounded-full flex items-center justify-center text-xs transition-all duration-200 shadow-sm <%= settings.tracking_mode !== 'percent' ? 'opacity-0 scale-75' : '' %>">
                                <i class="fa-solid fa-check"></i>
                            </div>
                            <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-primary text-lg mb-3 shadow-sm">
                                <i class="fa-solid fa-percent"></i>
                            </div>
                            <h3 class="font-bold text-gray-900">Percent</h3>
                            <p class="text-xs text-gray-500 mt-1">Estimate by visual percentage.</p>
                        </div>
                        <div id="mode-grams" class="selection-card <%= settings.tracking_mode === 'grams' ? 'selected' : '' %> cursor-pointer relative p-4 rounded-2xl border-2 <%= settings.tracking_mode === 'grams' ? 'border-primary bg-orange-50' : 'border-gray-100 bg-white' %> transition-all duration-200 hover:shadow-md" onclick="selectMode('grams')">
                            <div class="absolute top-3 right-3 check-icon w-5 h-5 bg-primary text-white rounded-full flex items-center justify-center text-xs transition-all duration-200 shadow-sm <%= settings.tracking_mode !== 'grams' ? 'opacity-0 scale-75' : '' %>">
                                <i class="fa-solid fa-check"></i>
                            </div>
                            <div class="w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 text-lg mb-3">
                                <i class="fa-solid fa-weight-hanging"></i>
                            </div>
                            <h3 class="font-bold text-gray-900">Grams</h3>
                            <p class="text-xs text-gray-500 mt-1">Precise tracking by weight.</p>
                        </div>
                    </div>
                    <input type="hidden" name="tracking_mode" id="tracking_mode" value="<%= settings.tracking_mode %>">
                </section>

                <section>
                    <div class="flex justify-between items-end mb-4">
                        <h2 class="text-xs md:text-sm font-semibold text-gray-900 flex items-center gap-2">
                            <i class="fa-solid fa-triangle-exclamation text-primary text-xs"></i> Low Threshold
                        </h2>
                        <span id="threshold-display" class="text-xl md:text-2xl font-bold text-primary"><%= settings.low_threshold %>%</span>
                    </div>
                    <div class="bg-white p-4 md:p-6 rounded-2xl border border-gray-100 shadow-sm">
                        <p class="text-[10px] md:text-xs text-gray-500 mb-6 uppercase tracking-wide font-semibold">Alert when below:</p>
                        <input type="range" name="low_threshold" id="threshold-slider" min="5" max="50" value="<%= settings.low_threshold %>" step="5" class="w-full" oninput="document.getElementById('threshold-display').innerText = this.value + '%'">
                        <div class="flex justify-between text-[10px] text-gray-300 mt-2 font-medium">
                            <span>5%</span><span>25%</span><span>50%</span>
                        </div>
                        <div class="mt-6 flex gap-2 overflow-x-auto pb-2">
                            <% [10, 15, 20, 25].forEach(v => { %>
                                <button type="button" onclick="setThreshold(<%= v %>)" class="flex-shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition-all border active:scale-95 <%= settings.low_threshold == v ? 'bg-orange-50 text-primary border-orange-200' : 'bg-gray-50 text-gray-600 border-transparent hover:bg-orange-50 hover:text-primary' %>"><%= v %>%</button>
                            <% }) %>
                        </div>
                    </div>
                </section>
            </form>
        </main>

        <div class="relative h-24 w-full mt-auto bg-white border-t border-gray-50 flex items-center justify-between px-6">
            <p class="text-[10px] md:text-xs text-gray-400 leading-tight max-w-[180px]">Settings can be updated anytime.</p>
            <div class="flex items-center gap-4">
                <a href="/filaments" class="text-xs font-bold text-gray-400 hover:text-gray-600 transition-colors uppercase tracking-widest">Skip</a>
                <button type="submit" form="setup-form" class="group relative w-14 h-14 bg-primary rounded-full flex items-center justify-center shadow-lg hover:bg-orange-600 transition-all active:scale-90 z-10">
                    <i class="fa-solid fa-check text-lg text-white group-hover:scale-110 transition-transform"></i>
                </button>
            </div>
        </div>
    </div>

    <script>
        function selectMode(mode) {
            document.getElementById('tracking_mode').value = mode;
            ['percent', 'grams'].forEach(m => {
                const el = document.getElementById('mode-' + m);
                if (m === mode) {
                    el.classList.add('selected', 'border-primary', 'bg-orange-50');
                    el.classList.remove('border-gray-100', 'bg-white');
                    el.querySelector('.check-icon').classList.remove('opacity-0', 'scale-75');
                } else {
                    el.classList.remove('selected', 'border-primary', 'bg-orange-50');
                    el.classList.add('border-gray-100', 'bg-white');
                    el.querySelector('.check-icon').classList.add('opacity-0', 'scale-75');
                }
            });
        }
        function setThreshold(val) {
            document.getElementById('threshold-slider').value = val;
            document.getElementById('threshold-display').innerText = val + '%';
        }
    </script>
</body>
</html>
