<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Add Filament - Photo</title>
    <style>
        .corner-border { position: absolute; width: 40px; height: 40px; border-color: white; border-style: solid; opacity: 0.8; }
        .top-left { top: 0; left: 0; border-width: 4px 0 0 4px; border-radius: 12px 0 0 0; }
        .top-right { top: 0; right: 0; border-width: 4px 4px 0 0; border-radius: 0 12px 0 0; }
        .bottom-left { bottom: 0; left: 0; border-width: 0 0 4px 4px; border-radius: 0 0 0 12px; }
        .bottom-right { bottom: 0; right: 0; border-width: 0 4px 4px 0; border-radius: 0 0 12px 0; }
        @keyframes scan { 0% { top: 0%; opacity: 0; } 10% { opacity: 1; } 90% { opacity: 1; } 100% { top: 100%; opacity: 0; } }
    </style>
</head>
<body class="bg-gray-100 text-gray-800 font-sans min-h-screen flex flex-col items-center justify-center p-0 sm:p-4">
    <div class="relative w-full max-w-md min-h-screen md:min-h-[850px] md:h-[850px] bg-black md:rounded-[40px] md:shadow-2xl overflow-hidden flex flex-col">

        <div class="absolute inset-0 z-0 bg-gray-900">
            <div class="w-full h-full bg-gradient-to-b from-gray-800 to-gray-900 flex items-center justify-center">
                <i class="fa-solid fa-camera text-6xl text-gray-700"></i>
            </div>
            <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/80"></div>
        </div>

        <div id="preview-area" class="hidden absolute inset-0 z-0 bg-gray-900">
            <img id="preview-img" class="w-full h-full object-cover opacity-90" src="" alt="Preview">
            <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/80"></div>
        </div>

        <header class="relative z-30 px-4 pt-6 pb-2">
            <div class="flex items-center justify-between mb-2">
                <a href="/filaments" class="w-10 h-10 flex items-center justify-center rounded-full bg-black/40 backdrop-blur-md text-white border border-white/20 hover:bg-black/60 active:scale-90 transition-all">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <h1 class="text-lg font-semibold text-white tracking-wide">Add Filament</h1>
                <a href="/filaments/new/details" class="px-3 py-1.5 rounded-full bg-black/40 backdrop-blur-md text-xs font-bold text-white border border-white/30 hover:bg-black/60 transition-all">Skip Photo</a>
            </div>
            <div class="flex items-center justify-center gap-2 mt-2">
                <div class="h-1.5 w-8 bg-primary rounded-full shadow-[0_0_10px_rgba(249,115,22,0.5)]"></div>
                <div class="h-1.5 w-8 bg-white/20 rounded-full backdrop-blur-sm"></div>
            </div>
            <p class="text-center text-xs text-white/80 mt-2 font-medium">Step 1 of 2: Capture Box</p>
        </header>

        <main class="relative z-20 flex-1 flex flex-col items-center justify-center px-6">
            <div class="relative w-full aspect-square max-w-[320px] mb-8 group" id="viewfinder">
                <div class="corner-border top-left"></div>
                <div class="corner-border top-right"></div>
                <div class="corner-border bottom-left"></div>
                <div class="corner-border bottom-right"></div>
                <div id="scan-line" class="absolute inset-x-4 top-0 h-0.5 bg-primary/80 shadow-[0_0_15px_rgba(249,115,22,0.8)] animate-[scan_3s_ease-in-out_infinite] opacity-60"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <p class="text-white text-sm font-bold bg-black/80 px-4 py-2 rounded-lg backdrop-blur-md border border-white/30 shadow-xl">
                        Take or upload a photo
                    </p>
                </div>
            </div>

            <p class="text-white/70 text-sm text-center max-w-[260px] mb-8">
                Take a photo of the filament box or upload from gallery.
            </p>

            <div class="w-full flex flex-col items-center gap-6 mt-auto pb-8">
                <div id="capture-controls" class="flex items-center justify-center w-full relative">
                    <label class="absolute left-4 md:left-8 w-12 h-12 rounded-xl bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer">
                        <i class="fa-regular fa-image text-lg"></i>
                        <input type="file" accept="image/*" class="hidden" id="gallery-input" onchange="handleFileSelect(this)">
                    </label>

                    <label class="w-20 h-20 rounded-full border-4 border-white flex items-center justify-center bg-transparent relative group transition-transform active:scale-95 cursor-pointer">
                        <div class="w-16 h-16 rounded-full bg-white group-hover:bg-gray-100 transition-colors"></div>
                        <input type="file" accept="image/*" capture="environment" class="hidden" id="camera-input" onchange="handleFileSelect(this)">
                    </label>

                    <div class="absolute right-4 md:right-8 w-12 h-12 rounded-xl bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white">
                        <i class="fa-solid fa-bolt text-lg"></i>
                    </div>
                </div>

                <div id="confirm-controls" class="hidden w-full flex-row items-center justify-between px-4 gap-4">
                    <button onclick="resetCapture()" class="flex-1 py-3.5 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 text-white font-medium hover:bg-white/20 transition-colors flex items-center justify-center gap-2">
                        <i class="fa-solid fa-rotate-left"></i> Retake
                    </button>
                    <button onclick="confirmPhoto()" class="flex-1 py-3.5 rounded-2xl bg-primary shadow-lg shadow-orange-500/30 text-white font-bold hover:bg-orange-600 transition-colors flex items-center justify-center gap-2">
                        Confirm <i class="fa-solid fa-check"></i>
                    </button>
                </div>
            </div>
        </main>

        <nav class="relative z-30 w-full bg-black/80 backdrop-blur-xl border-t border-white/10 px-6 py-3 flex justify-between items-center">
            <a href="/filaments" class="flex flex-col items-center gap-1 w-16"><div class="w-10 h-10 rounded-xl bg-primary/20 text-primary flex items-center justify-center"><i class="fa-solid fa-layer-group text-lg"></i></div><span class="text-[10px] font-semibold text-primary">Inventory</span></a>
            <a href="/filaments/low" class="flex flex-col items-center gap-1 w-16"><div class="w-10 h-10 rounded-xl text-gray-500 flex items-center justify-center"><i class="fa-solid fa-triangle-exclamation text-lg"></i></div><span class="text-[10px] font-medium text-gray-500">Low</span></a>
            <a href="/settings" class="flex flex-col items-center gap-1 w-16"><div class="w-10 h-10 rounded-xl text-gray-500 flex items-center justify-center"><i class="fa-solid fa-gear text-lg"></i></div><span class="text-[10px] font-medium text-gray-500">Settings</span></a>
        </nav>
    </div>

    <form id="photo-form" action="/filaments/new/details" method="GET" class="hidden">
        <input type="hidden" name="photo" id="photo-data">
    </form>

    <script>
        let selectedFile = null;

        function handleFileSelect(input) {
            if (input.files && input.files[0]) {
                selectedFile = input.files[0];
                const reader = new FileReader();
                reader.onload = (e) => {
                    document.getElementById('preview-img').src = e.target.result;
                    document.getElementById('preview-area').classList.remove('hidden');
                    document.getElementById('capture-controls').classList.add('hidden');
                    document.getElementById('confirm-controls').classList.remove('hidden');
                    document.getElementById('confirm-controls').classList.add('flex');
                    document.getElementById('scan-line').classList.add('hidden');
                };
                reader.readAsDataURL(e.target.result || input.files[0]);
                reader.readAsDataURL(input.files[0]);
            }
        }

        function resetCapture() {
            document.getElementById('preview-area').classList.add('hidden');
            document.getElementById('capture-controls').classList.remove('hidden');
            document.getElementById('confirm-controls').classList.add('hidden');
            document.getElementById('confirm-controls').classList.remove('flex');
            document.getElementById('scan-line').classList.remove('hidden');
            selectedFile = null;
        }

        function confirmPhoto() {
            // Store the file temporarily and redirect to details
            if (selectedFile) {
                sessionStorage.setItem('pendingPhoto', document.getElementById('preview-img').src);
            }
            window.location.href = '/filaments/new/details?hasPhoto=1';
        }
    </script>
</body>
</html>
