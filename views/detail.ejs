<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title><%= filament.brand %> - BambuTracker</title>
</head>
<body class="bg-gray-100 text-gray-800 font-sans min-h-screen flex flex-col items-center justify-center p-0 sm:p-4">
    <div class="relative w-full max-w-md min-h-screen md:min-h-0 md:max-h-[95vh] bg-surface md:rounded-[40px] md:shadow-2xl overflow-hidden flex flex-col">

        <header class="absolute top-0 left-0 right-0 z-30 px-6 pt-6 pb-4 flex items-center justify-between">
            <a href="/filaments" class="w-10 h-10 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-md text-white hover:bg-white/30 active:scale-95 transition-all border border-white/20 shadow-sm">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div class="relative">
                <button onclick="document.getElementById('actions-menu').classList.toggle('hidden')" class="w-10 h-10 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-md text-white hover:bg-white/30 active:scale-95 transition-all border border-white/20 shadow-sm">
                    <i class="fa-solid fa-ellipsis-vertical"></i>
                </button>
                <div id="actions-menu" class="hidden absolute right-0 top-12 bg-white rounded-xl shadow-modal border border-gray-100 py-2 w-44 z-50">
                    <a href="/filaments/<%= filament.id %>/edit" class="flex items-center gap-3 px-4 py-2 text-sm text-text-main hover:bg-gray-50"><i class="fa-regular fa-pen-to-square text-gray-400"></i>Edit Info</a>
                    <a href="/filaments/<%= filament.id %>/remaining" class="flex items-center gap-3 px-4 py-2 text-sm text-text-main hover:bg-gray-50"><i class="fa-solid fa-scale-balanced text-gray-400"></i>Update Remaining</a>
                    <hr class="my-1 border-gray-100">
                    <form action="/filaments/<%= filament.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this filament?')">
                        <button class="flex items-center gap-3 px-4 py-2 text-sm text-danger hover:bg-red-50 w-full"><i class="fa-regular fa-trash-can"></i>Delete</button>
                    </form>
                </div>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto hide-scrollbar bg-surface relative pb-24">
            <!-- Hero Image -->
            <div class="relative w-full h-[300px] sm:h-[340px] bg-gray-900 flex items-center justify-center overflow-hidden rounded-b-[3rem] shadow-lg z-10">
                <% if (filament.photo_url) { %>
                    <img class="w-full h-full object-cover opacity-90" src="<%= filament.photo_url %>" alt="<%= filament.brand %>">
                <% } else { %>
                    <div class="w-full h-full flex items-center justify-center" style="background: linear-gradient(135deg, <%= filament.color_hex %>40, <%= filament.color_hex %>)">
                        <i class="fa-solid fa-layer-group text-7xl text-white/60"></i>
                    </div>
                <% } %>
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-black/30"></div>
                <div class="absolute bottom-8 left-0 right-0 px-6 text-center text-white animate-fade-in">
                    <div class="inline-flex items-center gap-2 mb-2 px-3 py-1 rounded-full bg-white/10 backdrop-blur-md border border-white/20">
                        <span class="w-2 h-2 rounded-full shadow-[0_0_8px]" style="background-color: <%= filament.color_hex %>; box-shadow: 0 0 8px <%= filament.color_hex %>"></span>
                        <span class="text-xs font-medium tracking-wide uppercase"><%= filament.material %></span>
                    </div>
                    <h1 class="text-3xl font-bold tracking-tight mb-1"><%= filament.brand %></h1>
                    <p class="text-lg font-medium text-white/80"><%= filament.color %></p>
                </div>
            </div>

            <div class="px-5 -mt-6 relative z-20 space-y-5">
                <!-- Remaining Card -->
                <a href="/filaments/<%= filament.id %>/remaining" class="bg-white p-6 rounded-3xl shadow-soft border border-gray-100 animate-fade-in block hover:shadow-md transition-shadow">
                    <div class="flex justify-between items-center mb-6">
                        <div class="flex items-center gap-2">
                            <div class="w-10 h-10 rounded-2xl bg-orange-50 flex items-center justify-center text-primary"><i class="fa-solid fa-scale-balanced text-lg"></i></div>
                            <div>
                                <h3 class="text-sm font-bold text-text-main">Remaining</h3>
                                <p class="text-xs text-text-muted">Tap to update</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <% if (settings.tracking_mode === 'grams') { %>
                                <span class="text-2xl md:text-3xl font-bold text-primary"><%= Math.round(filament.total_weight * filament.remaining / 100) %></span>
                                <span class="text-sm font-medium text-text-muted">g</span>
                            <% } else { %>
                                <span class="text-2xl md:text-3xl font-bold text-primary"><%= filament.remaining %></span>
                                <span class="text-sm font-medium text-text-muted">%</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">
                        <div class="h-full rounded-full transition-all <%= filament.remaining <= settings.low_threshold ? 'bg-red-500' : 'bg-primary' %>" style="width: <%= filament.remaining %>%"></div>
                    </div>
                    <div class="flex justify-between text-xs font-medium text-gray-400 mt-2 px-1"><span>Empty</span><span>Full</span></div>
                </a>

                <!-- Status Card -->
                <div class="bg-white p-5 rounded-3xl shadow-soft border border-gray-100">
                    <div class="flex items-center gap-2 mb-3">
                        <i class="fa-solid fa-box-open text-text-muted text-xs"></i>
                        <h3 class="text-xs font-bold uppercase tracking-wider text-text-muted">Status</h3>
                    </div>
                    <div class="bg-surface p-1.5 rounded-2xl flex">
                        <% ['sealed', 'open', 'empty'].forEach(s => { %>
                            <form action="/filaments/<%= filament.id %>?_method=PUT" method="POST" class="flex-1">
                                <input type="hidden" name="brand" value="<%= filament.brand %>">
                                <input type="hidden" name="material" value="<%= filament.material %>">
                                <input type="hidden" name="color" value="<%= filament.color %>">
                                <input type="hidden" name="color_hex" value="<%= filament.color_hex %>">
                                <input type="hidden" name="remaining" value="<%= s === 'empty' ? 0 : filament.remaining %>">
                                <input type="hidden" name="total_weight" value="<%= filament.total_weight %>">
                                <input type="hidden" name="status" value="<%= s %>">
                                <input type="hidden" name="location" value="<%= filament.location || '' %>">
                                <input type="hidden" name="notes" value="<%= filament.notes || '' %>">
                                <button type="submit" class="w-full py-2.5 text-xs font-bold text-center rounded-xl transition-colors capitalize <%= filament.status === s ? 'bg-white shadow-sm text-text-main' : 'text-text-muted hover:text-text-main' %>"><%= s %></button>
                            </form>
                        <% }) %>
                    </div>
                </div>

                <!-- Location Card -->
                <a href="/filaments/<%= filament.id %>/edit" class="bg-white p-5 rounded-3xl shadow-soft border border-gray-100 flex items-center justify-between group cursor-pointer hover:border-primary/30 transition-colors block">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-2xl bg-blue-50 text-blue-500 flex items-center justify-center"><i class="fa-solid fa-location-dot"></i></div>
                        <div>
                            <h3 class="text-xs font-bold uppercase tracking-wider text-text-muted mb-0.5">Location</h3>
                            <p class="text-sm font-semibold text-text-main"><%= filament.location || 'Not set' %></p>
                        </div>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:bg-primary group-hover:text-white transition-all"><i class="fa-solid fa-pen text-xs"></i></div>
                </a>

                <!-- Notes Card -->
                <div class="bg-white p-5 rounded-3xl shadow-soft border border-gray-100">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <i class="fa-regular fa-note-sticky text-text-muted text-xs"></i>
                            <h3 class="text-xs font-bold uppercase tracking-wider text-text-muted">Notes</h3>
                        </div>
                        <a href="/filaments/<%= filament.id %>/edit" class="text-xs font-semibold text-primary hover:text-orange-700">Edit</a>
                    </div>
                    <p class="text-sm text-text-main leading-relaxed bg-surface p-4 rounded-xl border border-gray-100 min-h-[80px]">
                        <%= filament.notes || 'No notes yet.' %>
                    </p>
                </div>

                <!-- Action Buttons -->
                <div class="flex gap-3 pt-2 pb-6">
                    <a href="/filaments/<%= filament.id %>/edit" class="flex-1 flex items-center justify-center gap-2 py-3.5 px-4 rounded-2xl border border-gray-200 bg-white text-text-main font-semibold text-sm hover:bg-gray-50 active:scale-95 transition-all shadow-sm">
                        <i class="fa-regular fa-pen-to-square"></i>Edit Info
                    </a>
                    <form action="/filaments/<%= filament.id %>?_method=DELETE" method="POST" class="flex-1" onsubmit="return confirm('Delete this filament?')">
                        <button class="w-full flex items-center justify-center gap-2 py-3.5 px-4 rounded-2xl border border-gray-200 bg-white text-danger font-semibold text-sm hover:bg-red-50 hover:border-red-100 active:scale-95 transition-all shadow-sm">
                            <i class="fa-regular fa-trash-can"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        </main>

        <!-- Mark as Empty FAB -->
        <% if (filament.status !== 'empty') { %>
        <div class="absolute bottom-[90px] left-0 right-0 px-6 z-40 flex justify-center pointer-events-none">
            <form action="/filaments/<%= filament.id %>/remaining?_method=PUT" method="POST" class="pointer-events-auto">
                <input type="hidden" name="remaining" value="0">
                <input type="hidden" name="status" value="empty">
                <button class="bg-text-main text-white font-bold text-sm py-3 px-6 rounded-full shadow-lg hover:bg-black active:scale-95 transition-all flex items-center gap-2 opacity-90 hover:opacity-100">
                    <i class="fa-solid fa-box-open text-orange-500"></i><span>Mark as Empty</span>
                </button>
            </form>
        </div>
        <% } %>

        <% locals.activeNav = 'inventory' %>
        <%- include('partials/nav') %>
    </div>

    <script>
        // Close actions menu on outside click
        document.addEventListener('click', (e) => {
            const menu = document.getElementById('actions-menu');
            if (!e.target.closest('.relative')) menu.classList.add('hidden');
        });
    </script>
</body>
</html>
