<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Low Stock & Empty - BambuTracker</title>
</head>
<body class="bg-gray-100 text-gray-800 font-sans min-h-screen flex flex-col items-center justify-center p-0 sm:p-4">
    <div class="relative w-full max-w-md min-h-screen md:min-h-0 md:max-h-[95vh] bg-surface md:rounded-[40px] md:shadow-2xl overflow-hidden flex flex-col mx-auto">

        <header class="sticky top-0 z-40 px-4 sm:px-6 py-4 flex items-center justify-between bg-white/90 backdrop-blur-md border-b border-gray-100 shadow-sm">
            <h1 class="text-lg md:text-xl font-bold text-text-main">Low Stock & Empty</h1>
            <div class="flex items-center gap-2">
                <a href="/filaments" class="w-10 h-10 flex items-center justify-center rounded-full text-text-muted hover:text-primary hover:bg-orange-50 transition-colors">
                    <i class="fa-solid fa-layer-group text-sm"></i>
                </a>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto hide-scrollbar bg-surface relative p-4 md:p-6 pb-24">

            <!-- Summary Stats -->
            <div class="grid grid-cols-2 gap-4 mb-8">
                <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-red-50 text-danger flex items-center justify-center text-xl"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <div>
                        <p class="text-xs text-text-muted font-medium">Low Stock</p>
                        <p class="text-xl font-bold text-text-main"><%= lowStock.length %></p>
                    </div>
                </div>
                <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-gray-100 text-gray-500 flex items-center justify-center text-xl"><i class="fa-solid fa-box-open"></i></div>
                    <div>
                        <p class="text-xs text-text-muted font-medium">Empty</p>
                        <p class="text-xl font-bold text-text-main"><%= empty.length %></p>
                    </div>
                </div>
            </div>

            <% if (lowStock.length === 0 && empty.length === 0) { %>
                <div class="flex flex-col items-center justify-center py-12 px-6 text-center animate-fade-in">
                    <div class="w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mb-4">
                        <i class="fa-solid fa-check text-success text-3xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-text-main mb-2">All Stocked Up!</h3>
                    <p class="text-sm text-text-muted max-w-xs">No filament spools running low or empty right now.</p>
                    <a href="/filaments" class="mt-6 px-6 py-3 bg-white border border-gray-200 text-text-main font-medium rounded-xl shadow-sm hover:bg-gray-50 transition-colors">View Full Inventory</a>
                </div>
            <% } %>

            <!-- Low Stock Section -->
            <% if (lowStock.length > 0) { %>
                <div class="mb-8 animate-fade-in">
                    <div class="py-2 flex items-center justify-between mb-4">
                        <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-warning"></span>
                            Low Stock (<span class="text-warning">Below <%= settings.low_threshold %>%</span>)
                        </h2>
                    </div>
                    <div class="space-y-3">
                        <% lowStock.forEach(f => { %>
                            <div class="bg-white rounded-2xl p-4 shadow-card border border-gray-100 flex items-center gap-4 hover:border-warning/30 transition-all">
                                <a href="/filaments/<%= f.id %>" class="w-16 h-16 rounded-xl overflow-hidden bg-gray-50 border border-gray-100 flex-shrink-0 relative block">
                                    <% if (f.photo_url) { %>
                                        <img class="w-full h-full object-cover" src="<%= f.photo_url %>" alt="<%= f.brand %>">
                                    <% } else { %>
                                        <div class="w-full h-full flex items-center justify-center" style="background-color: <%= f.color_hex %>20">
                                            <i class="fa-solid fa-layer-group text-lg" style="color: <%= f.color_hex %>"></i>
                                        </div>
                                    <% } %>
                                    <div class="absolute bottom-0 left-0 right-0 bg-black/50 h-1.5"><div class="bg-warning h-full" style="width: <%= f.remaining %>%"></div></div>
                                </a>
                                <a href="/filaments/<%= f.id %>" class="flex-1 min-w-0 block">
                                    <div class="flex justify-between items-start mb-1">
                                        <h3 class="font-bold text-text-main text-base truncate pr-2"><%= f.brand %></h3>
                                        <span class="text-xs font-bold <%= f.remaining <= 10 ? 'text-danger bg-danger/10' : 'text-warning bg-warning/10' %> px-2.5 py-1 rounded-md"><%= f.remaining %>%</span>
                                    </div>
                                    <p class="text-sm text-text-muted truncate"><%= f.material %> &bull; <%= f.color %></p>
                                    <div class="flex items-center gap-2 mt-2">
                                        <span class="text-xs text-gray-400 bg-gray-50 px-2 py-1 rounded border border-gray-100"><%= Math.round(f.total_weight * f.remaining / 100) %>g left</span>
                                        <% if (f.location) { %><span class="text-xs text-gray-400"><i class="fa-solid fa-location-dot mr-1"></i><%= f.location %></span><% } %>
                                    </div>
                                </a>
                                <form action="/filaments/<%= f.id %>/restock?_method=PUT" method="POST">
                                    <button class="w-12 h-12 rounded-xl bg-gray-50 text-success hover:bg-success hover:text-white transition-all flex items-center justify-center shadow-sm border border-gray-100" title="Restock">
                                        <i class="fa-solid fa-rotate-right text-lg"></i>
                                    </button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% } %>

            <!-- Empty Section -->
            <% if (empty.length > 0) { %>
                <div class="mb-8 animate-fade-in">
                    <div class="py-2 flex items-center justify-between mb-4">
                        <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-gray-400"></span>
                            Empty (<span class="text-gray-500">0%</span>)
                        </h2>
                    </div>
                    <div class="space-y-3">
                        <% empty.forEach(f => { %>
                            <div class="bg-white/60 rounded-2xl p-4 shadow-sm border border-gray-200 border-dashed flex items-center gap-4 opacity-80 hover:opacity-100 hover:bg-white transition-all">
                                <a href="/filaments/<%= f.id %>" class="w-16 h-16 rounded-xl overflow-hidden bg-gray-100 border border-gray-200 flex-shrink-0 relative grayscale block">
                                    <% if (f.photo_url) { %>
                                        <img class="w-full h-full object-cover" src="<%= f.photo_url %>" alt="<%= f.brand %>">
                                    <% } else { %>
                                        <div class="w-full h-full flex items-center justify-center bg-gray-200"><i class="fa-solid fa-ban text-gray-400 text-xl"></i></div>
                                    <% } %>
                                </a>
                                <a href="/filaments/<%= f.id %>" class="flex-1 min-w-0 block">
                                    <div class="flex justify-between items-start mb-1">
                                        <h3 class="font-bold text-text-muted text-base truncate pr-2 line-through decoration-gray-400"><%= f.brand %></h3>
                                        <span class="text-xs font-bold text-gray-500 bg-gray-100 px-2.5 py-1 rounded-md">Empty</span>
                                    </div>
                                    <p class="text-sm text-text-muted truncate"><%= f.material %> &bull; <%= f.color %></p>
                                </a>
                                <form action="/filaments/<%= f.id %>/restock?_method=PUT" method="POST">
                                    <button class="w-12 h-12 rounded-xl bg-primary/10 text-primary hover:bg-primary hover:text-white transition-all flex items-center justify-center shadow-sm border border-primary/20" title="Restock">
                                        <i class="fa-solid fa-rotate-right text-lg"></i>
                                    </button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% } %>
        </main>

        <% locals.activeNav = 'low' %>
        <%- include('partials/nav') %>
    </div>
</body>
</html>
