<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Welcome - BambuTracker</title>
    <style>
        .blob-shape { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; animation: morph 8s ease-in-out infinite; }
        @keyframes morph {
            0%, 100% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; }
            34% { border-radius: 70% 30% 50% 50% / 30% 30% 70% 70%; }
            67% { border-radius: 100% 60% 60% 100% / 100% 100% 60% 60%; }
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans min-h-screen flex flex-col items-center justify-center overflow-hidden">
    <div class="relative w-full max-w-md h-[100dvh] md:h-[850px] bg-white md:rounded-[40px] md:shadow-2xl overflow-hidden flex flex-col justify-between">

        <header class="relative z-20 flex justify-between items-center p-6 pt-8">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white font-bold">
                    <i class="fa-solid fa-layer-group"></i>
                </div>
            </div>
            <a href="/filaments" class="text-gray-500 font-medium hover:text-gray-800 transition-colors text-sm">Skip</a>
        </header>

        <main class="flex-1 flex flex-col relative z-10 px-6 pb-20 md:pb-0">
            <div class="flex-1 flex items-center justify-center relative">
                <div class="absolute w-64 h-64 bg-orange-50 rounded-full blob-shape -z-10 transform translate-y-4"></div>
                <div class="relative w-full max-w-[300px] aspect-square flex items-center justify-center">
                    <div class="w-48 h-48 bg-orange-100 rounded-3xl flex items-center justify-center">
                        <i class="fa-solid fa-layer-group text-7xl text-primary"></i>
                    </div>
                </div>
            </div>

            <div class="mt-4 mb-12 text-center md:text-left md:px-4">
                <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">
                    Track Filament <br>
                    <span class="text-primary">Photo-First</span> & Fast
                </h1>
                <p class="text-gray-500 text-base md:text-lg leading-relaxed max-w-xs mx-auto md:mx-0">
                    Snap a photo to instantly identify what it is, how much is left, and where it's stored.
                </p>
            </div>

            <div class="flex justify-center md:justify-start md:px-4 gap-2 mb-8">
                <div class="w-6 h-2 bg-primary rounded-full"></div>
                <div class="w-2 h-2 bg-gray-200 rounded-full"></div>
                <div class="w-2 h-2 bg-gray-200 rounded-full"></div>
            </div>
        </main>

        <div class="relative h-32 w-full mt-auto">
            <div class="absolute bottom-0 right-0 w-[180px] h-[140px] bg-secondary rounded-tl-[100px] z-10 flex items-center justify-center pl-8 pt-8">
                <a href="/setup" class="group relative w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-lg hover:bg-gray-100 transition-all duration-300 transform hover:scale-105 active:scale-95">
                    <i class="fa-solid fa-arrow-right text-xl text-secondary group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>
            <div class="absolute bottom-8 left-6 md:hidden z-20">
                <a href="/setup" class="text-gray-600 text-sm font-semibold hover:text-primary transition-colors">How it works?</a>
            </div>
        </div>
    </div>
</body>
</html>
